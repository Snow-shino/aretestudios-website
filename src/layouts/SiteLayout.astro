---
import '../styles/site.css';

const {
  title = 'Snocrest Plugins',
  description = 'Unreal Engine plugins, documentation, and buyer support from Snocrest.',
} = Astro.props;

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const url = (path: string) => `${base}${path.replace(/^\//, '')}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#ff7a1a" />
    <title>{title}</title>
  </head>
  <body>
    <header class="topbar">
      <div class="shell topbar-inner">
        <a class="brand" href={url('/')}>
          <img src={url('/ase2ue-mark.svg')} alt="" width="34" height="34" />
          <span>Snocrest Plugins</span>
        </a>
        <nav class="nav" aria-label="Main navigation">
          <a href={url('/plugins')}>Plugins</a>
          <a href={url('/plugins/ase2ue')}>Ase2UE</a>
          <a href={url('/docs/ase2ue')}>Docs</a>
          <a href={url('/docs/ase2ue/changelog')}>Changelog</a>
        </nav>
      </div>
    </header>
    <slot />
    <footer class="footer">
      <div class="shell">
        <p>Snocrest Plugins. Static documentation and plugin support for Unreal Engine creators.</p>
      </div>
    </footer>
  </body>
</html>
