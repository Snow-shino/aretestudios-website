---
import SiteLayout from '../layouts/SiteLayout.astro';

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const url = (path: string) => `${base}${path.replace(/^\//, '')}`;
---

<SiteLayout
  title="Snocrest Plugins"
  description="Plugin showcase and documentation for Snocrest Unreal Engine tools."
>
  <main>
    <section class="shell hero">
      <div>
        <p class="eyebrow">Unreal Engine creator tools</p>
        <h1>Focused plugins for faster 2D production.</h1>
        <p class="lead">
          Snocrest Plugins is the home for practical Unreal Engine tools, buyer documentation,
          and support resources. The first release is Ase2UE, an Aseprite-to-Paper2D workflow plugin.
        </p>
        <div class="actions">
          <a class="button primary" href={url('/plugins/ase2ue')}>View Ase2UE</a>
          <a class="button" href={url('/docs/ase2ue')}>Read the Docs</a>
        </div>
      </div>
      <aside class="docs-panel" aria-label="Ase2UE documentation chapters">
        <div class="docs-panel-head">
          <img src={url('/ase2ue-mark.svg')} alt="" width="42" height="42" />
          <div>
            <h2>Ase2UE Docs</h2>
            <p>Quick setup, importing, sockets, FAQ, and release notes.</p>
          </div>
        </div>
        <nav class="chapter-list" aria-label="Documentation chapters">
          <a href={url('/docs/ase2ue/getting-started')}>
            <span>01</span>
            <strong>Getting Started</strong>
            <small>Install, enable Paper2D, set Aseprite path.</small>
          </a>
          <a href={url('/docs/ase2ue/importing')}>
            <span>02</span>
            <strong>Importing</strong>
            <small>Grid, Auto JSON, flipbooks, reimport.</small>
          </a>
          <a href={url('/docs/ase2ue/hitboxes-hurtboxes-sockets')}>
            <span>03</span>
            <strong>Hitboxes, Hurtboxes & Sockets</strong>
            <small>Marker layers and PaperSprite sockets.</small>
          </a>
          <a href={url('/docs/ase2ue/faq')}>
            <span>04</span>
            <strong>FAQ</strong>
            <small>Common setup and import fixes.</small>
          </a>
        </nav>
      </aside>
    </section>

    <section class="section">
      <div class="shell">
        <div class="section-head">
          <div>
            <p class="eyebrow">Plugin showcase</p>
            <h2>Built for concrete workflows.</h2>
          </div>
          <p>
            Each plugin page explains what the tool does, who it is for, and where to find setup docs,
            support notes, and changelogs.
          </p>
        </div>
        <div class="grid">
          <article class="card">
            <h3>Buyer-friendly docs</h3>
            <p>Simple setup steps, searchable keywords, and troubleshooting written for working creators.</p>
          </article>
          <article class="card">
            <h3>Static and fast</h3>
            <p>No WordPress and no runtime server. The site builds to static files for DreamHost hosting.</p>
          </article>
          <article class="card">
            <h3>Launch-ready paths</h3>
            <p>Docs URLs are stable and ready to use in Fab listings, support replies, and videos.</p>
          </article>
        </div>
      </div>
    </section>
  </main>
</SiteLayout>
