---
import SiteLayout from '../layouts/SiteLayout.astro';

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const url = (path: string) => `${base}${path.replace(/^\//, '')}`;

const chapters = [
  {
    number: '01',
    title: 'Ase2UE Getting Started',
    description: 'Install Ase2UE, enable Paper2D, set the Aseprite executable path, and import your first file.',
    href: '/docs/ase2ue/getting-started',
    keywords: 'install setup paper2d aseprite executable path first import source asset',
  },
  {
    number: '02',
    title: 'Ase2UE Importing',
    description: 'Use Ase2 Source assets, output folders, Grid extraction, Auto JSON extraction, and reimport.',
    href: '/docs/ase2ue/importing',
    keywords: 'import ase2 source destination grid auto json reimport texture sprite flipbook',
  },
  {
    number: '03',
    title: 'TileForge2D Quick Start',
    description: 'Create tilesets, maps, layers, and map actors for a first TileForge2D test.',
    href: '/docs/tileforge2d/quick-start',
    keywords: 'tileforge tileforge2d quick start tileset map actor layer paint collision',
  },
  {
    number: '04',
    title: 'Tile Actors & Smart Tiles',
    description: 'Plan doors, chests, pots, destructibles, particles, sounds, and grid-bound actors.',
    href: '/docs/tileforge2d/tile-actors',
    keywords: 'tile actors smart tiles chest door destructible particles sounds interaction blueprint',
  },
  {
    number: '05',
    title: 'Ase2UE Hitboxes, Hurtboxes & Sockets',
    description: 'Create marker layers for SOCKET_, HIT_, and HURT_ workflows in Paper2D.',
    href: '/docs/ase2ue/hitboxes-hurtboxes-sockets',
    keywords: 'socket sockets hitbox hurtbox marker layer weapon hand trace paper sprite',
  },
  {
    number: '06',
    title: 'FAQ & Troubleshooting',
    description: 'Fix common setup, Aseprite path, file picker, flipbook, marker, and socket issues.',
    href: '/docs/ase2ue/faq',
    keywords: 'faq troubleshooting errors warnings aseprite path sockets flipbooks file picker',
  },
  {
    number: '07',
    title: 'Changelog',
    description: 'Review release notes and version history for Ase2UE.',
    href: '/docs/ase2ue/changelog',
    keywords: 'changelog release notes version history updates',
  },
];
---

<SiteLayout
  title="Arête Plugin Documentation"
  description="Searchable Arête plugin documentation for Ase2UE and TileForge2D."
>
  <main>
    <section class="shell hero docs-hero">
      <div>
        <p class="eyebrow">Arête Plugin Documentation</p>
        <h1>Unreal Engine plugin docs for 2D creators.</h1>
        <p class="lead">
          Find setup guides, workflow notes, and QA checklists for Ase2UE and TileForge2D.
          Ase2UE handles Aseprite import workflows; TileForge2D handles game-ready tile maps.
        </p>
        <div class="actions">
          <a class="button primary" href={url('/docs/tileforge2d')}>Open TileForge Docs</a>
          <a class="button" href={url('/docs/ase2ue')}>Open Ase2UE Docs</a>
          <a class="button" href={url('/plugins/ase2ue')}>View Plugin Page</a>
          <a class="button" href={url('/plugins/tileforge2d')}>View TileForge2D</a>
        </div>
      </div>

      <aside class="docs-panel" aria-label="Documentation search">
        <div class="docs-panel-head">
          <img src={url('/ase2ue-mark.svg')} alt="" width="42" height="42" />
          <div>
            <h2>Find Instructions</h2>
            <p>Search setup, importing, tile maps, Tile Actors, projections, sockets, and QA help.</p>
          </div>
        </div>
        <div class="search-box">
          <label for="docs-search">Search documentation</label>
          <input
            id="docs-search"
            type="search"
            placeholder="Search: Tile Actors, sockets, Grid, Aseprite path..."
            autocomplete="off"
          />
        </div>
      </aside>
    </section>

    <section class="section docs-directory">
      <div class="shell">
        <div class="section-head">
          <div>
            <p class="eyebrow">Chapters</p>
            <h2>Choose a documentation chapter.</h2>
          </div>
          <p>
            These are the buyer-facing docs linked from the plugin and Fab listing. The full guide is
            also searchable inside the documentation pages.
          </p>
        </div>
        <div class="chapter-grid" id="chapter-grid">
          {chapters.map((chapter) => (
            <a
              class="chapter-card"
              href={url(chapter.href)}
              data-search={`${chapter.title} ${chapter.description} ${chapter.keywords}`.toLowerCase()}
            >
              <span>{chapter.number}</span>
              <strong>{chapter.title}</strong>
              <small>{chapter.description}</small>
            </a>
          ))}
        </div>
        <p class="no-results" id="no-results" hidden>No matching documentation chapters.</p>
      </div>
    </section>
  </main>

  <script>
    const input = document.getElementById('docs-search') as HTMLInputElement | null;
    const cards = Array.from(document.querySelectorAll<HTMLElement>('[data-search]'));
    const noResults = document.getElementById('no-results');

    input?.addEventListener('input', () => {
      const query = input.value.trim().toLowerCase();
      let visibleCount = 0;

      for (const card of cards) {
        const matches = !query || card.dataset.search?.includes(query);
        card.toggleAttribute('hidden', !matches);
        if (matches) visibleCount += 1;
      }

      if (noResults) {
        noResults.hidden = visibleCount > 0;
      }
    });
  </script>
</SiteLayout>
