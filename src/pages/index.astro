---
import SiteLayout from '../layouts/SiteLayout.astro';
import TileForgeWord from '../components/TileForgeWord.astro';

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const url = (path: string) => `${base}${path.replace(/^\//, '')}`;

const plugins = [
  {
    name: 'Ase2UE',
    label: 'Aseprite import pipeline',
    description:
      'Import saved Aseprite files into Unreal Engine and generate Paper2D textures, sprites, flipbooks, sockets, and optional hitbox helper data.',
    icon: '/ase2ue-mark.svg',
    pluginHref: '/plugins/ase2ue',
    docsHref: '/docs/ase2ue',
    repoHref: 'https://github.com/Snow-shino/Ase2ue',
    status: 'Under review',
  },
  {
    name: 'TileForge2D',
    label: '2D world-building tools',
    description:
      'Create game-ready tile maps in Unreal with tilesets, layers, collision, Tile Actors, destructibles, projection modes, and Blueprint hooks.',
    icon: '/tileforge2d-mark.svg',
    pluginHref: '/plugins/tileforge2d',
    docsHref: '/docs/tileforge2d',
    repoHref: 'https://github.com/Snow-shino/TileForge2D',
    status: 'In development',
  },
  {
    name: 'DayNight2D',
    label: 'World time and schedules',
    description:
      'Add Blueprint-friendly time, calendar, schedules, routines, timed behavior, optional day/night visuals, and multiplayer-aware world timing.',
    icon: '/daynight2d-mark.svg',
    pluginHref: '/plugins/daynight2d',
    docsHref: '/docs/daynight2d',
    repoHref: 'https://github.com/Snow-shino/DayNight2D',
    status: 'Foundation QA',
  },
  {
    name: 'SpriteSort2D',
    label: 'Top-down 2D sprite sorting',
    description:
      'Sort Paper2D sprites, flipbooks, and primitive visuals by visual depth without moving collision or relying on translucent materials.',
    icon: '/spritesort2d-mark.svg',
    pluginHref: '/spritesort2d',
    docsHref: '/spritesort2d',
    repoHref: 'https://github.com/Snow-shino',
    status: 'Free MVP',
  },
  {
    name: 'FlipbookWidget',
    label: 'Paper2D animation for UMG',
    description:
      'Display and control Paper2D flipbooks directly in UMG with Blueprint playback, sizing, tint, color variation, and events.',
    icon: '/flipbookwidget-icon.png',
    pluginHref: '/FlipbookWidget',
    docsHref: '/FlipbookWidget/how-to',
    repoHref: 'https://github.com/Snow-shino',
    status: 'Fab ready',
  },
];

const chapters = [
  {
    number: '01',
    title: 'Ase2UE Getting Started',
    description: 'Install Ase2UE, enable Paper2D, set the Aseprite executable path, and import your first file.',
    href: '/docs/ase2ue/getting-started',
    keywords: 'install setup paper2d aseprite executable path first import source asset',
  },
  {
    number: '02',
    title: 'Ase2UE Importing',
    description: 'Use Ase2 Source assets, output folders, Grid extraction, Auto JSON extraction, and reimport.',
    href: '/docs/ase2ue/importing',
    keywords: 'import ase2 source destination grid auto json reimport texture sprite flipbook',
  },
  {
    number: '03',
    title: 'TileForge2D Quick Start',
    description: 'Create tilesets, maps, layers, and map actors for a first TileForge2D test.',
    href: '/docs/tileforge2d/quick-start',
    keywords: 'tileforge tileforge2d quick start tileset map actor layer paint collision',
  },
  {
    number: '04',
    title: 'Tile Actors & Smart Tiles',
    description: 'Plan doors, chests, pots, destructibles, particles, sounds, and grid-bound actors.',
    href: '/docs/tileforge2d/tile-actors',
    keywords: 'tile actors smart tiles chest door destructible particles sounds interaction blueprint',
  },
  {
    number: '05',
    title: 'DayNight2D Getting Started',
    description: 'Create settings, start world time, and wire Blueprint systems to time events.',
    href: '/docs/daynight2d/getting-started',
    keywords: 'daynight2d time calendar schedule blueprint settings events',
  },
  {
    number: '06',
    title: 'DayNight2D Blueprint API',
    description: 'Review Blueprint nodes for time, dates, schedules, routines, timed behavior, save/load, and replication.',
    href: '/docs/daynight2d/blueprint-api',
    keywords: 'daynight2d blueprint api nodes schedule routine save load multiplayer',
  },
  {
    number: '07',
    title: 'Ase2UE Hitboxes, Hurtboxes & Sockets',
    description: 'Create marker layers for SOCKET_, HIT_, and HURT_ workflows in Paper2D.',
    href: '/docs/ase2ue/hitboxes-hurtboxes-sockets',
    keywords: 'socket sockets hitbox hurtbox marker layer weapon hand trace paper sprite',
  },
  {
    number: '08',
    title: 'FAQ & Troubleshooting',
    description: 'Fix common setup, Aseprite path, file picker, flipbook, marker, and socket issues.',
    href: '/docs/ase2ue/faq',
    keywords: 'faq troubleshooting errors warnings aseprite path sockets flipbooks file picker',
  },
  {
    number: '09',
    title: 'SpriteSort2D Quick Start',
    description: 'Add visual-depth sprite sorting to a Paper2D actor without hand-placing an origin first.',
    href: '/spritesort2d#quick-start',
    keywords: 'spritesort2d quick start visual depth sorting visualroot origin masked paper2d',
  },
  {
    number: '10',
    title: 'SpriteSort2D QA Checklist',
    description: 'Verify collision safety, masked materials, update modes, and scale before release.',
    href: '/spritesort2d#qa-checklist',
    keywords: 'spritesort2d qa checklist collision materials performance shipping',
  },
  {
    number: '11',
    title: 'Changelog',
    description: 'Review release notes and version history for Ase2UE.',
    href: '/docs/ase2ue/changelog',
    keywords: 'changelog release notes version history updates',
  },
  {
    number: '12',
    title: 'FlipbookWidget How To',
    description: 'Install the plugin, add the widget to UMG, assign a PaperFlipbook, and control playback.',
    href: '/FlipbookWidget/how-to',
    keywords: 'flipbook widget paper2d umg install setup playback animated ui',
  },
  {
    number: '13',
    title: 'FlipbookWidget Blueprint API',
    description: 'Review playback, frame, sizing, tint, variation, and event controls.',
    href: '/FlipbookWidget/blueprint-api',
    keywords: 'flipbook widget blueprint api play pause tint frame events sizing',
  },
];
---

<SiteLayout
  title="Arete Plugins"
  description="Unreal Engine plugin landing page for Arete tools, including Ase2UE and TileForge2D."
>
  <main>
    <section class="shell hero landing-hero">
      <div>
        <p class="eyebrow">Arete Plugins</p>
        <h1>Unreal Engine tools for 2D creators.</h1>
        <p class="lead">
          A focused plugin hub for artists, solo developers, and small teams building 2D games in Unreal Engine.
          Start with Ase2UE for art import workflows, then use <TileForgeWord /> for game-ready maps.
        </p>
        <div class="actions">
          <a class="button primary" href={url('/plugins')}>Browse Plugins</a>
          <a class="button" href={url('/docs/ase2ue')}>Open Ase2UE Docs</a>
          <a class="button" href={url('/docs/tileforge2d')}>Open TileForge Docs</a>
        </div>
      </div>

      <aside class="landing-panel" aria-label="Plugin catalog summary">
        <div class="terminal-header">
          <span>plugin catalog</span>
          <span>2D</span>
        </div>
        <div class="landing-stack">
          {plugins.map((plugin) => (
            <a class="mini-plugin" href={url(plugin.pluginHref)}>
              <img src={url(plugin.icon)} alt="" width="42" height="42" />
              <span>
                <strong>
                  {plugin.name === 'Ase2UE' ? (
                    <>Ase<span class="ase-two">2</span>UE</>
                  ) : plugin.name === 'SpriteSort2D' ? (
                    <>Sprite<span class="sort-orange">Sort</span>2D</>
                  ) : plugin.name === 'FlipbookWidget' ? (
                    <><span class="flipbook-neon">Flipbook</span>Widget</>
                  ) : (
                    <TileForgeWord />
                  )}
                </strong>
                <small>{plugin.label}</small>
              </span>
            </a>
          ))}
        </div>
      </aside>
    </section>

    <section class="section plugin-showcase">
      <div class="shell">
        <div class="section-head">
          <div>
            <p class="eyebrow">Plugins</p>
            <h2>Choose a workflow.</h2>
          </div>
          <p>
            Each plugin gets its own page, docs section, and support path. This homepage is the master landing page for the full Arete plugin catalog.
          </p>
        </div>

        <div class="plugin-card-grid">
          {plugins.map((plugin) => (
            <article class="plugin-card">
              <div class="plugin-card-head">
                <img src={url(plugin.icon)} alt="" width="58" height="58" />
                <div>
                  <p class="eyebrow">{plugin.status}</p>
                  <h3>
                    {plugin.name === 'Ase2UE' ? (
                      <>Ase<span class="ase-two">2</span>UE</>
                    ) : plugin.name === 'SpriteSort2D' ? (
                      <>Sprite<span class="sort-orange">Sort</span>2D</>
                    ) : plugin.name === 'FlipbookWidget' ? (
                      <><span class="flipbook-neon">Flipbook</span>Widget</>
                    ) : (
                      <TileForgeWord />
                    )}
                  </h3>
                </div>
              </div>
              <p>{plugin.description}</p>
              <div class="actions">
                <a class="button primary" href={url(plugin.pluginHref)}>Plugin Page</a>
                <a class="button" href={url(plugin.docsHref)}>Docs</a>
                <a class="button" href={plugin.repoHref}>GitHub</a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section docs-directory">
      <div class="shell">
        <div class="section-head">
          <div>
            <p class="eyebrow">Documentation</p>
            <h2>Jump straight into the docs.</h2>
          </div>
          <p>Search the most common setup and workflow chapters across the current plugin catalog.</p>
        </div>

        <div class="docs-panel docs-search-panel" aria-label="Documentation search">
          <div class="docs-panel-head">
            <img src={url('/ase2ue-mark.svg')} alt="" width="42" height="42" />
            <div>
              <h2>Find Instructions</h2>
              <p>Search setup, importing, tile maps, Tile Actors, projections, sockets, and QA help.</p>
            </div>
          </div>
          <div class="search-box">
            <label for="docs-search">Search documentation</label>
            <input
              id="docs-search"
              type="search"
              placeholder="Search: Tile Actors, sockets, Grid, Aseprite path..."
              autocomplete="off"
            />
          </div>
        </div>

        <div class="chapter-grid" id="chapter-grid">
          {chapters.map((chapter) => (
            <a
              class="chapter-card"
              href={url(chapter.href)}
              data-search={`${chapter.title} ${chapter.description} ${chapter.keywords}`.toLowerCase()}
            >
              <span>{chapter.number}</span>
              <strong>{chapter.title === 'TileForge2D Quick Start' ? <><TileForgeWord /> Quick Start</> : chapter.title}</strong>
              <small>{chapter.description}</small>
            </a>
          ))}
        </div>
        <p class="no-results" id="no-results" hidden>No matching documentation chapters.</p>
      </div>
    </section>

    <section class="section">
      <div class="shell">
        <div class="section-head">
          <div>
            <p class="eyebrow">Direct Links</p>
            <h2>Review-safe plugin paths.</h2>
          </div>
          <p>Ase2UE keeps its existing docs URL while <TileForgeWord /> and Sprite<span class="sort-orange">Sort</span>2D live beside it as separate plugin sections.</p>
        </div>
        <div class="grid">
          <article class="card">
            <h3>Ase<span class="ase-two">2</span>UE</h3>
            <p>The review docs path remains unchanged.</p>
            <p><a href={url('/docs/ase2ue')}>/docs/ase2ue/</a></p>
          </article>
          <article class="card">
            <h3><TileForgeWord /></h3>
            <p><TileForgeWord /> has its own docs section on the same site.</p>
            <p><a href={url('/docs/tileforge2d')}>/docs/tileforge2d/</a></p>
          </article>
          <article class="card">
            <h3>Sprite<span class="sort-orange">Sort</span>2D</h3>
            <p>SpriteSort2D has a searchable setup and QA page.</p>
            <p><a href={url('/spritesort2d')}>/spritesort2d/</a></p>
          </article>
          <article class="card">
            <h3><span class="flipbook-neon">Flipbook</span>Widget</h3>
            <p>Arete Flipbook Widgets has dedicated setup, Blueprint API, and troubleshooting guides.</p>
            <p><a href={url('/FlipbookWidget')}>/FlipbookWidget/</a></p>
          </article>
        </div>
      </div>
    </section>
  </main>

  <script>
    const input = document.getElementById('docs-search') as HTMLInputElement | null;
    const cards = Array.from(document.querySelectorAll<HTMLElement>('[data-search]'));
    const noResults = document.getElementById('no-results');

    input?.addEventListener('input', () => {
      const query = input.value.trim().toLowerCase();
      let visibleCount = 0;

      for (const card of cards) {
        const matches = !query || card.dataset.search?.includes(query);
        card.toggleAttribute('hidden', !matches);
        if (matches) visibleCount += 1;
      }

      if (noResults) {
        noResults.hidden = visibleCount > 0;
      }
    });
  </script>
</SiteLayout>
