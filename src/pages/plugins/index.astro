---
import SiteLayout from '../../layouts/SiteLayout.astro';

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const url = (path: string) => `${base}${path.replace(/^\//, '')}`;
---

<SiteLayout
  title="Plugins | Arête Plugins"
  description="Browse Arête Unreal Engine plugins."
>
  <main>
    <section class="shell hero">
      <div>
        <p class="eyebrow">Plugins</p>
        <h1>Unreal Engine tools from Arête.</h1>
        <p class="lead">
          A small catalog of focused production tools. Each plugin includes documentation,
          setup steps, and support guidance.
        </p>
      </div>
      <article class="terminal-card">
        <div class="terminal-header">
          <span>catalog</span>
          <span>v1</span>
        </div>
        <pre class="terminal-body"><code>available:
  - Ase2UE
  - TileForge2D

category:
  - 2D
  - Paper2D
  - Aseprite workflow
  - Tile map workflow</code></pre>
      </article>
    </section>

    <section class="section">
      <div class="shell">
        <div class="plugin-row">
          <img src={url('/ase2ue-mark.svg')} alt="" width="58" height="58" />
          <div>
            <h2>Ase<span class="ase-two">2</span>UE</h2>
            <p>Import Aseprite files into Unreal Engine and generate Paper2D textures, sprites, flipbooks, and sprite sockets.</p>
          </div>
          <a class="button primary" href={url('/plugins/ase2ue')}>Open</a>
        </div>
        <div class="plugin-row">
          <img src={url('/tileforge2d-mark.svg')} alt="" width="58" height="58" />
          <div>
            <h2>TileForge2D</h2>
            <p>Build game-ready 2D maps in Unreal with tilesets, layers, collision, Tile Actors, projection modes, and Blueprint hooks.</p>
          </div>
          <a class="button primary" href={url('/plugins/tileforge2d')}>Open</a>
        </div>
      </div>
    </section>
  </main>
</SiteLayout>
